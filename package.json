{
  "name": "anonymcp-server",
  "version": "0.1.0",
  "description": "Local MCP server that pseudonymizes documents before exposing them to external LLMs (privacy by design, Italian legal focus).",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "bin": {
    "anonymcp-server": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "anonymcp.config.example.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "start": "node dist/index.js",
    "app:dev": "electron-vite dev --entry=out/main/index.js",
    "app:build": "electron-vite build",
    "app:typecheck": "tsc -p tsconfig.electron.json --noEmit",
    "review": "node --import tsx src/tui/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js",
    "gen:fixtures": "node --import tsx scripts/generateFixtures.ts",
    "gen:test-pratiche": "node --import tsx scripts/generateTestPractices.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.6.2",
    "lucide-react": "^0.475.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.25.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.30",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.5.0",
    "electron": "^40.10.2",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^7.3.5",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
